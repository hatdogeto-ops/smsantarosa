<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fillWidth="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.taskmate.controller.TaskController">
   <children>
    <!--   INPUT    -->
      <VBox prefHeight="179.0" prefWidth="621.0">
         <children>
            <VBox fillWidth="false" prefHeight="42.0" prefWidth="600.0">
               <children>
                  <Label text="Task" />
                  <TextField fx:id="taskInput" prefHeight="25.0" prefWidth="457.0" />
               </children>
            </VBox>
            <VBox prefHeight="56.0" prefWidth="600.0">
               <children>
                  <Label text="Deadline" />
                  <DatePicker fx:id="deadlineInput" />
               </children>
            </VBox>
            <Button fx:id="addTaskBtn" mnemonicParsing="false" onAction="#addTask" text="Add Task" />
         </children>
      </VBox>


      <Label text="Tasks" />

      <TableView fx:id="taskTable" prefHeight="190.0" prefWidth="610.0">
        <columns>
          <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="taskColumn" prefWidth="75.0" text="Task" />
          <TableColumn fx:id="deadlineColumn" prefWidth="75.0" text="Deadline" />
        </columns>
      </TableView>
      <HBox fillHeight="false" prefHeight="5.0" prefWidth="600.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleRefresh" text="Refresh" />
            <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#logout" text="Logout" />
         </children>
      </HBox>
   </children>
</VBox>
